    "projectsGuide": {
      "intro": {
        "title": "Welcome",
        "content": "Welcome to Vibe Kanban. Use the help sections in this panel to learn how things work, then create your first issue. You can re-open this help dialog or give feedback anytime from the navbar."
      },
      "welcome": {
        "title": "Projects",
        "content": "The project page is where you manage issues. You can view your issues as a kanban board, or as a list, and filter by status, tag, assignee and more."
      },
      "issues": {
        "title": "Issues",
        "content": "Each issue represents a feature or problem to solve. Issues have statuses, priorities, assignees, tags, relationships, comments, sub-issues and more."
      },
      "workspaces": {
        "title": "Sessions",
        "content": "To start working on an issue, create a session. A single issue can have multiple sessions. Issues describe the work to be done, sessions are where the work happens."
      },
      "organizations": {
        "title": "Invite your team",
        "content": "We've automatically created a personal organization and initial project so you can get started with Vibe Kanban. Export your cloud data before shutdown."
