  "workspacesGuide": {
    "welcome": {
      "title": "Welcome",
      "content": "Welcome to the Sessions page. One view of the sessions across all of your projects, and the fastest way to review work from your agents. Share feedback anytime via the navbar icon."
    },
    "commandBar": {
      "title": "Command Bar",
      "content": "The command bar is your central hub for navigation. Open it with CMD+K to search and access every action available in a session."
    },
    "contextBar": {
      "title": "Context Bar",
      "content": "The context bar lets you switch between panes quickly. Drag it wherever works best for you."
    },
    "sidebar": {
      "title": "Session Sidebar",
      "content": "See the status of all your sessions at a glance. Notifications highlight which ones need attention. Archive merged sessions to keep your sidebar clean."
    },
    "multiRepo": {
      "title": "Multi-Repo Support",
      "content": "Add multiple repos to a single session. Reference code from one repo while working in another, or implement changes across several repos at once."
    },
    "sessions": {
      "title": "Multiple Sessions",
      "content": "Create multiple agent conversation sessions within a single session, including sessions with different agents. This helps you work around conversation limits or spin up review agents in separate threads."
    },
    "preview": {
      "title": "Preview Changes",
      "content": "Preview your work in a built-in browser without switching contexts. Test across desktop, mobile, and custom viewport sizes."
    },
    "diffs": {
      "title": "Diffs and Comments",
      "content": "The redesigned diffs panel includes a file tree of your changes. Comment directly on diffs to give feedback to the agent, and view GitHub comments when your session is linked to a PR."
    },
    "classicUi": {
      "title": "Return to Classic UI",
      "content": "Click the exit icon on the left side of the navbar to return to the classic kanban board. To disable the new UI entirely, update the \"Enable Sessions Beta\" option under \"Beta Features\" in settings."
    }
  },
